# ==============================================================================
# polymarket-legend-mm — environment configuration
# ==============================================================================
# Copy this file to `.env` and fill in the values.
# The `.env` file is gitignored. Never commit private keys or passwords.
# ==============================================================================

# --- Polygon RPC ---
# Use a dedicated Alchemy/Infura/QuickNode URL. Public RPCs will rate-limit the bot.
POLYGON_RPC_URL="https://polygon-rpc.com"

# --- Keystore password ---
# Used to encrypt/decrypt wallet keystores in data/keystore/.
# Pick a strong random password and store it in a password manager.
# If you lose this password, the wallets are unrecoverable.
KEYSTORE_PASSWORD="change-me-to-a-strong-random-password"

# --- Bot mode ---
# MODE=paper → no real orders placed; events logged to SQLite only.
# MODE=live  → places real orders on Polymarket.
MODE="paper"

# --- Safety: dry run ---
# Even in MODE=live, set DRY_RUN=true for an extra layer that prevents order placement.
# Must explicitly set DRY_RUN=false to submit real orders.
DRY_RUN="true"

# --- Canary mode (optional) ---
# If set, only this wallet index (0..7) is active. Use for first live run with reduced caps.
# CANARY_ONLY=""

# --- Risk parameters (override shared/src/markets.ts defaults) ---
# MAX_POSITION_USD_PER_MARKET="100"
# MAX_DAILY_DRAWDOWN_USD="200"
# SPREAD_TICKS="2"
# ORDER_SIZE_USD="25"
# POLL_INTERVAL_MS="2000"
# HEARTBEAT_INTERVAL_MS="5000"

# --- Collateral override (for Polymarket USD migration) ---
# When Polymarket USD ships, paste its address here to override the default USDC.e.
# COLLATERAL_TOKEN_ADDRESS=""
# COLLATERAL_TOKEN_SYMBOL=""
# COLLATERAL_TOKEN_DECIMALS=""

# --- Exchange overrides (future-proofing for contract migrations) ---
# Leave blank to use the defaults from @polymarket/order-utils at runtime.
# NEG_RISK_EXCHANGE=""
# NEG_RISK_ADAPTER=""
# CTF_ADDRESS=""

# --- Dashboard ---
DASHBOARD_PORT="3000"
