{
  "name": "polymarket-legend-mm",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-wallet market-making bot for Polymarket, with local monitoring dashboard",
  "scripts": {
    "bot": "pnpm --filter @polymm/bot dev",
    "dashboard": "pnpm --filter @polymm/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "treasury:generate": "pnpm --filter @polymm/scripts tsx src/generate-treasury.ts",
    "wallets:generate": "pnpm --filter @polymm/scripts tsx src/generate-wallets.ts",
    "wallets:fund": "pnpm --filter @polymm/scripts tsx src/fund-wallets.ts",
    "wallets:approve": "pnpm --filter @polymm/scripts tsx src/grant-approvals.ts",
    "wallets:sweep": "pnpm --filter @polymm/scripts tsx src/sweep.ts",
    "status": "pnpm --filter @polymm/scripts tsx src/status.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0"
  }
}
