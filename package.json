{
  "name": "polymarket-legend-mm",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-wallet market-making bot for Polymarket, with local monitoring dashboard",
  "scripts": {
    "bot": "pnpm --filter @polymm/bot dev",
    "dashboard": "pnpm --filter @polymm/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "treasury:generate": "pnpm --filter @polymm/scripts run treasury:generate",
    "treasury:probe": "pnpm --filter @polymm/scripts run treasury:probe",
    "treasury:export-keys": "pnpm --filter @polymm/scripts run treasury:export-keys",
    "activate:usdc": "pnpm --filter @polymm/scripts run activate:usdc",
    "wallets:generate": "pnpm --filter @polymm/scripts run wallets:generate",
    "wallets:fund": "pnpm --filter @polymm/scripts run wallets:fund",
    "wallets:approve": "pnpm --filter @polymm/scripts run wallets:approve",
    "wallets:sweep": "pnpm --filter @polymm/scripts run wallets:sweep",
    "status": "pnpm --filter @polymm/scripts run status"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0"
  }
}
